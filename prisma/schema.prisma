generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(100)
  password   String    @db.VarChar(100)
  role       Role      @default(penumpang)
  pelanggan  Pelanggan?
  petugas    Petugas?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

enum Role {
  admin
  penumpang
}

model Pelanggan {
  id              Int               @id @default(autoincrement())
  NIK             String            @unique @db.VarChar(100)
  nama_penumpang  String            @db.VarChar(100)
  alamat          String?
  telp            String?           @db.VarChar(20)
  id_user         Int               @unique
  user            Users             @relation(fields: [id_user], references: [id])
  pembelian_tiket PembelianTiket[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Petugas {
  id           Int      @id @default(autoincrement())
  nama_petugas String   @db.VarChar(100)
  alamat       String?
  telp         String?  @db.VarChar(20)
  id_user      Int      @unique
  user         Users    @relation(fields: [id_user], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Kereta {
  id            Int       @id @default(autoincrement())
  nama_kereta   String    @db.VarChar(100)
  deskripsi     String?
  kelas         String
  gerbong       Gerbong[]
  jadwal        Jadwal[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Gerbong {
  id           Int      @id @default(autoincrement())
  nama_gerbong String
  kuota        Int
  id_kereta    Int
  kereta       Kereta   @relation(fields: [id_kereta], references: [id])
  kursi        Kursi[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Kursi {
  id              Int             @id @default(autoincrement())
  no_kursi        String
  id_gerbong      Int
  gerbong         Gerbong         @relation(fields: [id_gerbong], references: [id])
  detail_pembelian DetailPembelian[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Jadwal {
  id                     Int              @id @default(autoincrement())
  asal_keberangkatan     String           @db.VarChar(100)
  tujuan_keberangkatan   String           @db.VarChar(100)
  tanggal_berangkat      DateTime
  tanggal_kedatangan     DateTime
  harga                  Float
  id_kereta              Int
  kereta                 Kereta           @relation(fields: [id_kereta], references: [id])
  pembelian_tiket        PembelianTiket[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model PembelianTiket {
  id                Int               @id @default(autoincrement())
  tanggal_pembelian DateTime          @default(now())
  id_pelanggan      Int
  id_jadwal         Int
  pelanggan         Pelanggan         @relation(fields: [id_pelanggan], references: [id])
  jadwal            Jadwal            @relation(fields: [id_jadwal], references: [id])
  detail_pembelian  DetailPembelian[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model DetailPembelian {
  id                  Int            @id @default(autoincrement())
  NIK                 String         @db.VarChar(100)
  nama_penumpang      String         @db.VarChar(100)
  id_pembelian_tiket  Int
  id_kursi            Int
  pembelian_tiket     PembelianTiket @relation(fields: [id_pembelian_tiket], references: [id])
  kursi               Kursi          @relation(fields: [id_kursi], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}